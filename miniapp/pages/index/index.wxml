<view class="page-shell">
  <view class="glass-panel hero-panel">
    <view class="section-line"></view>
    <view class="hero-copy">
      <text class="hero-eyebrow">CEREMONY SEAT LOOKUP</text>
      <text class="hero-title">开幕式座位查询</text>
      <text class="hero-description">输入姓名后即可查询座位信息。小程序支持本地数据检索，也可切换为后端 API 查询。</text>
    </view>

    <view class="search-panel">
      <text class="panel-label">Name</text>
      <input
        class="search-input"
        placeholder="例如：张三"
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
        hold-keyboard="true"
      />
      <view class="button-row">
        <button class="search-button" bindtap="onSearch" loading="{{loading}}" disabled="{{loading}}">{{loading ? '查询中...' : '开始查询'}}</button>
        <button class="clear-button" bindtap="onClear" disabled="{{loading}}">重置</button>
      </view>
      <text wx:if="{{error}}" class="error-text">{{error}}</text>
    </view>
  </view>

  <view class="result-header" wx:if="{{hasSearched}}">
    <text class="result-title">查询结果{{results.length > 1 ? '（' + results.length + '）' : ''}}</text>
    <text class="result-subtitle">{{results.length > 0 ? '滑动向下查看座位信息' : '未查询到匹配结果'}}</text>
  </view>

  <view class="empty-panel" wx:if="{{hasSearched && !error && results.length === 0}}">
    <text class="empty-title">未找到匹配结果</text>
    <text class="empty-description">请尝试更完整或更接近的姓名关键字。</text>
  </view>

  <view class="result-list" wx:if="{{results.length > 0}}">
    <view class="result-card" wx:for="{{results}}" wx:key="id">
      <view class="card-top">
        <view class="card-copy">
          <text class="card-label">Guest</text>
          <text class="card-title">{{item.title}}</text>
          <text class="card-subtitle">{{item.subtitle}}</text>
        </view>
        <text class="card-badge">{{item.zone}}</text>
      </view>
      <view class="metric-grid">
        <view class="metric-card">
          <text class="metric-label">区域</text>
          <text class="metric-value">{{item.zone}}</text>
        </view>
        <view class="metric-card">
          <text class="metric-label">排号</text>
          <text class="metric-value">{{item.row}}</text>
        </view>
        <view class="metric-card">
          <text class="metric-label">座位</text>
          <text class="metric-value">{{item.seat}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
